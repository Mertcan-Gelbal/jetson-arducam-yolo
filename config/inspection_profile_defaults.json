{
  "version": 1,
  "camera_name": "VisionDock Inspection Station",
  "board_model": "JETSON_ORIN_NANO",
  "output_backend": "mock",
  "trigger_mode": "manual",
  "runtime": {
    "host": "127.0.0.1",
    "port": 8787
  },
  "camera": {
    "backend": "mock_frame",
    "sensor_model": "GENERIC_CSI",
    "focuser_type": "none",
    "sensor_id": 0,
    "device_index": 0,
    "capture_width": 1920,
    "capture_height": 1080,
    "display_width": 1280,
    "display_height": 720,
    "framerate": 30,
    "flip_method": 0,
    "aelock": false,
    "warmup_frames": 4,
    "frame_skip": 1,
    "burst_count": 3,
    "source_path": "",
    "preview_source_label": "Development mock frame"
  },
  "inspection": {
    "profile_name": "default_project",
    "recipe_name": "default_recipe",
    "product_label": "Inspection target",
    "expected_object_label": "target",
    "pass_display_label": "Pass",
    "review_display_label": "Review required",
    "fail_display_label": "Fail",
    "defect_catalog": [
      "missing_target",
