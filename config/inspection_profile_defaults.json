      "x": 0.0,
      "y": 0.0,
      "width": 1.0,
      "height": 1.0
    },
    "heuristic": {
      "min_laplacian_var": 60.0,
      "min_mean_intensity": 55.0,
      "max_mean_intensity": 205.0,
      "min_edge_density": 0.01,
      "max_edge_density": 0.22
    }
  },
  "model": {
    "name": "No model deployed",
    "version": "unassigned"
  },
  "gpio": {
    "enabled": false,
    "active_level": "high",
    "pass_pin": 15,
    "fail_pin": 16,
    "fault_pin": 18,
    "busy_pin": 33,
    "trigger_pin": null
